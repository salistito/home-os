# General
TZ=America/Santiago

# Database
HOME_OS_DB_PATH=./homeos.db

# Telegram
TELEGRAM_BOT_TOKEN=#Your Telegram Bot Token
SEBASTIAN_TELEGRAM_CHAT_ID=#Your Telegram Chat ID
ANTONIA_TELEGRAM_CHAT_ID=#Your Telegram Chat ID

# Webhook (production)
WEBHOOK_URL=#https://homeos.fly.dev
WEBHOOK_SECRET=#Token aleatorio [A-Za-z0-9_-], p.ej. openssl rand -hex 32
PORT=8080

# Auth
JWT_SECRET=#Token aleatorio para firmar los JWT, p.ej. openssl rand -hex 32
JWT_TTL_DAYS=365

# Web CORS
WEB_ALLOWED_ORIGINS=Allowed web urls to request interal API

# Administrative web app
WEB_PORT=8000

# cron-job.org
CRONJOB_ORG_API_KEY=#cron-job.org API key
