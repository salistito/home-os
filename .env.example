# General
TZ=America/Santiago

# App Name
APP_NAME= # Your home-os app name

# Database
HOME_OS_DB_PATH=./homeos.db # Path to the SQLite database file

# Telegram Bot
TELEGRAM_BOT_TOKEN= # Bot token from @BotFather

# Webhooks (production only)
WEBHOOK_URL= # Public URL where the bot receives updates (e.g. https://home-os.fly.dev)
WEBHOOK_SECRET= # Shared secret to validate incoming webhook requests (generate with: openssl rand -hex 32)
PORT=8080 # Port for the webhook server

# Authentication
JWT_SECRET= # Secret key used to sign JWTs (generate with: openssl rand -hex 32)
JWT_TTL_DAYS=365 # Number of days before a JWT expires

# Web App
WEB_ALLOWED_ORIGINS= # Comma-separated list of allowed CORS origins (e.g. "https://app.example.com")
WEB_PORT=8000 # Port for the web admin API

# External Cron Service
CRONJOB_ORG_API_KEY= # API key for cron-job.org (used to trigger daily assignments and reminders)
